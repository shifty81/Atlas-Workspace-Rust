# ── NovaForge local assets (binary files — fetched via fetch_novaforge_assets.sh) ──
# The directory structure and README.md are tracked; actual asset blobs are not.
novaforge-assets/**/*.png
novaforge-assets/**/*.jpg
novaforge-assets/**/*.jpeg
novaforge-assets/**/*.vox
novaforge-assets/**/*.ttf
novaforge-assets/**/*.otf
